generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(STAFF)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  vehicles     Vehicle[]  @relation("CreatedBy")
  auditLogs    AuditLog[]
  approvalHistory ApprovalHistory[]
}

enum Role {
  ADMIN
  STAFF
  ACCOUNTS
}

model Vehicle {
  id                 String        @id @default(uuid())
  confirmationNumber String        @unique
  vin                String        @unique
  registrationNumber String
  make               String
  model              String
  year               Int
  odometer           Int
  sellerPrice        Float?
  location           String?
  sellerName         String
  sellerPhone        String
  sellerEmail        String
  submissionSource   Source        @default(STAFF_ENTRY)
  submissionToken    String?
  ipAddress          String?
  status             VehicleStatus @default(PENDING_VERIFICATION)
  riskScore          Int           @default(0)
  riskFlags          Json          @default("[]")

  // Framework v2 fields
  dealStatus              DealStatus     @default(SOURCED)
  sellerType              SellerType     @default(PRIVATE_INDIVIDUAL)
  ppsrPath                PpsrPath       @default(NO_DEPOSIT)
  depositPaidCents        Int            @default(0)
  depositPaidAt           DateTime?
  loadFeeCents            Int            @default(25000)
  resalePriceCents        Int?
  inspectionCostCents     Int?
  inspectionBookedAt      DateTime?
  inspectionCompletedAt   DateTime?
  inspectionPassed        Boolean?
  inspectionReportUrl     String?
  contractSignedAt        DateTime?
  paidAt                  DateTime?
  closedAt                DateTime?
  cancelledAt             DateTime?
  cancelReason            String?
  sellerAbn               String?
  sellerAcn               String?
  sellerGstRegistered     Boolean?
  assignedSalesUserId     String?
  buyerDealerId           String?
  buyerDealer             BuyerDealer?   @relation(fields: [buyerDealerId], references: [id])
  adminNotes         Json          @default("[]")
  sellerSignature    String?
  signedAt           DateTime?
  isCompanyVehicle   Boolean       @default(false)
  companyName        String?
  companyAbn         String?
  submittedAt        DateTime      @default(now())
  autograbVehicleId    String?
  autograbTradeValue   Float?
  autograbRetailValue  Float?
  autograbColour       String?
  autograbEngine       String?
  autograbTransmission String?
  autograbBodyType     String?
  inspectionCondition  String?
  inspectionRepairCost Float?
  inspectionNotes      String?
  inspectedAt          DateTime?
  docusignEnvelopeId   String?
  docusignStatus       String        @default("NOT_SENT")
  docusignSignedAt     DateTime?
  purchasePrice        Float?
  offerPrice           Float?
  soldAt               DateTime?
  soldPrice            Float?
  accountsApprovedAt   DateTime?
  accountsApprovedById String?
  easycarsSyncedAt     DateTime?
  approvalStatus       ApprovalStatus @default(PENDING)
  approvalComment      String?
  stockStatus          StockStatus    @default(AWAITING_DELIVERY)
  createdById        String?
  createdBy          User?         @relation("CreatedBy", fields: [createdById], references: [id])
  identity           SellerIdentity?
  ownership          OwnershipRecord?
  ppsrCheck          PPSRCheck?
  saleAgreement           SaleAgreement?
  billOfSale              BillOfSale?
  inspectionAuthorisation InspectionAuthorisation?
  ddChecklist             DDChecklist?
  spotterFee              SpotterFee?
  gstRegisterEntries      GSTRegisterEntry[]
  documents               Document[]
  auditLogs               AuditLog[]
  approvalHistory         ApprovalHistory[]
  invoices                ApplicationInvoice[]
  expenses                ApplicationExpense[]
  ppsrRecords             PPSRRecord[]
}

enum Source {
  PUBLIC_PORTAL
  STAFF_ENTRY
  SINGLE_USE_LINK
}

enum VehicleStatus {
  PENDING_VERIFICATION
  DOCUMENTS_MISSING
  RISK_FLAGGED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockStatus {
  AWAITING_DELIVERY
  IN_STOCK
  SOLD
  WITHDRAWN
}

enum DealStatus {
  SOURCED
  UNDER_OFFER
  CONTRACT_SIGNED
  COMMITTED
  APPROVED_FOR_PAYMENT
  PAYMENT_READY
  PAID
  LISTED
  SOLD
  CLOSED
  CANCELLED_DD_FAIL
  CANCELLED_INSPECTION_FAIL
}

enum SellerType {
  PRIVATE_INDIVIDUAL
  PRIVATE_COMPANY
  LMCT_DEALER
}

enum PpsrPath {
  DEPOSIT_AND_LODGE
  DEPOSIT_ONLY
  NO_DEPOSIT
}

model SellerIdentity {
  id                   String    @id @default(uuid())
  vehicleId            String    @unique
  vehicle              Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  fullLegalName        String
  address              String
  driversLicenceNumber String
  licenceState         String
  licenceExpiry        DateTime
  licenceFrontDocId    String?
  licenceBackDocId     String?
  selfieDocId          String?
  regoCertDocId        String?
  bankStatementDocId   String?
  verifiedAt           DateTime?
  verifiedById         String?
}

model OwnershipRecord {
  id           String   @id @default(uuid())
  vehicleId    String   @unique
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentType String
  notes        String?
  createdAt    DateTime @default(now())
}

model PPSRCheck {
  id               String   @id @default(uuid())
  vehicleId        String   @unique
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  checkedAt        DateTime @default(now())
  checkedById      String?
  isWrittenOff     Boolean  @default(false)
  isStolen         Boolean  @default(false)
  hasFinance       Boolean  @default(false)
  certificateDocId String?
  rawResult        Json?
  status           String   @default("PENDING")
}

model Document {
  id           String   @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  category     String
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model SubmissionToken {
  id                 String   @id @default(uuid())
  token              String   @unique
  vehicleVin         String?
  vehicleMake        String?
  vehicleModel       String?
  vehicleYear        Int?
  vehicleOdometer    Int?
  vehicleRego        String?
  vehicleColour      String?
  vehicleBodyType    String?
  vehicleTransmission String?
  used               Boolean  @default(false)
  expiresAt          DateTime
  createdAt          DateTime @default(now())
}

model Settings {
  id             String  @id @default("singleton")
  dealershipName String  @default("Direct Auto Wholesale")
  logoPath       String?
  primaryColor   String  @default("#1e40af")
  contactEmail   String?
  notifyOnSubmit Boolean @default(true)
  notifyOnPPSR   Boolean @default(true)
  abn            String?
}

model SaleAgreement {
  id            String    @id @default(uuid())
  vehicleId     String    @unique
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  salePrice     Float
  buyerName     String
  buyerEmail    String
  buyerPhone    String?
  buyerAddress  String?
  agreementDate DateTime  @default(now())
  sentAt        DateTime?
  sentById      String?
  status        String    @default("DRAFT")
  signingToken  String?   @unique
  signedAt      DateTime?
  signerIp      String?
  signerName    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BillOfSale {
  id                  String              @id @default(uuid())
  vehicleId           String              @unique
  vehicle             Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Seller details
  sellerFullName      String
  sellerAddress       String?
  sellerSuburb        String?
  sellerState         String?
  sellerPostcode      String?
  sellerCustomerId    String?
  sellerDob           String?
  sellerPhone         String
  sellerEmail         String
  sellerLicenceNumber String?

  // Vehicle details (snapshot at time of creation)
  registrationNumber  String
  stateOfRegistration String?
  vinNumber           String
  engineNumber        String?
  yearOfManufacture   Int
  vehicleMake         String
  vehicleModel        String
  vehicleVariant      String?
  bodyType            String?
  colour              String?
  fuelType            String?
  transmission        String?
  odometerReading     Int
  numberOfKeys        String?

  // Sale details
  purchasePrice       Float
  depositPaid         Float              @default(0)
  balanceDue          Float
  paymentMethod       String?
  dateOfSale          DateTime           @default(now())

  // Vehicle condition
  knownDefects        String?

  // Status & signing
  status              String             @default("DRAFT")
  signingToken        String?            @unique
  tokenExpiresAt      DateTime?
  sentAt              DateTime?
  sentById            String?
  viewedAt            DateTime?

  // Seller signature
  signedAt            DateTime?
  signerName          String?
  signerIp            String?
  signerUserAgent     String?
  signatureData       String?

  // PDF
  pdfStoragePath      String?

  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  events              BillOfSaleEvent[]
}

model BillOfSaleEvent {
  id           String     @id @default(uuid())
  billOfSaleId String
  billOfSale   BillOfSale @relation(fields: [billOfSaleId], references: [id], onDelete: Cascade)
  action       String
  details      Json?
  ipAddress    String?
  userAgent    String?
  userId       String?
  createdAt    DateTime   @default(now())
}

model ApprovalHistory {
  id            String   @id @default(uuid())
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String   // submitted, approved, rejected, resubmitted
  comment       String?
  createdAt     DateTime @default(now())

  @@index([vehicleId])
}

model ApplicationInvoice {
  id                String   @id @default(uuid())
  vehicleId         String
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  invoiceNumber     String   @unique
  buyerName         String
  buyerEmail        String
  buyerAddress      String?
  vehicleDescription String
  subtotalCents     Int
  gstCents          Int
  totalCents        Int
  pdfUrl            String?
  sentAt            DateTime?
  sentToEmail       String?
  dueDate           DateTime?
  paidAt            DateTime?
  buyerDealerId     String?
  createdByUserId   String
  createdAt         DateTime @default(now())
  collectionActions CollectionAction[]

  @@index([vehicleId])
  @@index([createdAt])
}

model InvoiceSequence {
  id      String @id @default("singleton")
  lastNum Int    @default(0)
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  expenses  ApplicationExpense[]
}

model ApplicationExpense {
  id              String          @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  amountCents     Int
  expenseDate     DateTime
  supplier        String?
  notes           String?
  receiptFileUrl  String?
  source          String          @default("manual") // manual, ppsr_auto, invoice_auto
  createdByUserId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([vehicleId])
  @@index([expenseDate])
}

model PPSRRecord {
  id                  String    @id @default(uuid())
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  registrationNumber  String?
  lodgedAt            DateTime?
  expiresAt           DateTime?
  status              String    @default("pending") // pending, active, expired, failed, discharged
  feeCents            Int       @default(0)
  provider            String?
  providerReference   String?
  requestPayload      Json?
  responsePayload     Json?
  errorMessage        String?
  dischargedAt        DateTime?
  dischargedByUserId  String?
  createdByUserId     String
  createdAt           DateTime  @default(now())

  @@index([vehicleId])
}

// ============================================================================
// Framework v2 Models
// ============================================================================

model InspectionAuthorisation {
  id              String    @id @default(uuid())
  vehicleId       String    @unique
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ownerName       String
  vehicleLocation String?
  status          String    @default("DRAFT") // DRAFT, SENT, SIGNED
  signingToken    String?   @unique
  sentAt          DateTime?
  sentById        String?
  signedAt        DateTime?
  signerName      String?
  signerIp        String?
  signerUserAgent String?
  signatureData   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BuyerDealer {
  id                String    @id @default(uuid())
  name              String
  contactName       String?
  email             String?
  phone             String?
  address           String?
  abn               String?
  lmctNumber        String?
  riskRating        String    @default("STANDARD") // LOW, STANDARD, HIGH
  creditStatus      String    @default("ACTIVE") // ACTIVE, SUSPENDED, FROZEN, BLACKLISTED
  creditSuspendedAt DateTime?
  blacklistedAt     DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  vehicles          Vehicle[]
  collectionActions CollectionAction[]
}

model DDChecklist {
  id                      String    @id @default(uuid())
  vehicleId               String    @unique
  vehicle                 Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  // Stage 1 checks (1st approver)
  inspectionReviewed      Boolean   @default(false)
  inspectionReviewedAt    DateTime?
  licenceVerified         Boolean   @default(false)
  licenceVerifiedAt       DateTime?
  regoOwnerConfirmed      Boolean   @default(false)
  regoOwnerConfirmedAt    DateTime?
  ppsrConfirmed           Boolean   @default(false)
  ppsrConfirmedAt         DateTime?
  bankVerified            Boolean   @default(false)
  bankVerifiedAt          DateTime?
  financePayoutVerified   Boolean   @default(false)
  financePayoutVerifiedAt DateTime?
  financePayoutNa         Boolean   @default(false)
  // Stage 1 completion
  stage1CompletedAt       DateTime?
  stage1CompletedById     String?
  // Stage 2 approval (2nd approver)
  stage2ApprovedAt        DateTime?
  stage2ApprovedById      String?
  stage2RejectedAt        DateTime?
  stage2RejectionReason   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model CommissionRate {
  id            String    @id @default(uuid())
  userId        String
  ratePercent   Int       @default(25) // 25 or 50
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  setByUserId   String?
  createdAt     DateTime  @default(now())

  @@index([userId])
}

model SpotterFee {
  id                String    @id @default(uuid())
  vehicleId         String    @unique
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  salesUserId       String
  ratePercent       Int
  resalePriceCents  Int
  costPriceCents    Int
  totalExpensesCents Int
  loadFeeCents      Int       @default(25000)
  netProfitCents    Int
  feeAmountCents    Int
  calculatedAt      DateTime  @default(now())
  lockedAt          DateTime?
  paidAt            DateTime?
  paidInPayrollCycle String?
  adjustmentNotes   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model GSTRegisterEntry {
  id                  String    @id @default(uuid())
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  acquisitionDate     DateTime
  sellerName          String
  sellerAbn           String?
  sellerGstRegistered Boolean   @default(false)
  purchasePriceCents  Int
  resalePriceCents    Int?
  marginCents         Int?
  notionalGstCents    Int?
  basQuarter          String?   // e.g., "Q1", "Q2", "Q3", "Q4"
  basYear             Int?
  gstCreditUnlockedAt DateTime?
  notes               String?
  createdAt           DateTime  @default(now())

  @@index([basQuarter, basYear])
  @@index([vehicleId])
}

model CollectionAction {
  id            String      @id @default(uuid())
  invoiceId     String
  invoice       ApplicationInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  buyerDealerId String?
  buyerDealer   BuyerDealer? @relation(fields: [buyerDealerId], references: [id])
  actionType    String      // REMINDER_DUE_SOON, REMINDER_OVERDUE, PHONE_CALL, FORMAL_EMAIL, CREDIT_SUSPENDED, ACCOUNT_FROZEN, DEMAND_LETTER, EXTERNAL_RECOVERY
  dueDate       DateTime?
  daysOverdue   Int?
  sentAt        DateTime?
  sentVia       String?     // email, sms, phone, letter
  completedAt   DateTime?
  completedById String?
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([invoiceId])
  @@index([buyerDealerId])
}
